# Personality (Groq free tier). Optional — the fallback thought table runs without it.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# The paired wall device presents this bearer token to receive private panels.
MAWA_DEVICE_TOKEN=

# Unlocks the dashboard companion tester in production (open on localhost if unset).
MAWA_DASHBOARD_ADMIN_TOKEN=

# Display time zone for greetings, calendar times, and day-part.
MAWA_TIME_ZONE=America/New_York

# Calendars via secret iCal URLs (Google Calendar → Settings → "Secret address in
# iCal format"). No OAuth, no client credentials, no token storage.
MAWA_CALENDAR_PERSONAL_ICS=
MAWA_CALENDAR_WORK_ICS=
